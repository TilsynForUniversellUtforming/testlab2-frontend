{
  "name": "testlab2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint:fix": "eslint ./src --ext .jsx,.js,.ts,.tsx --quiet --fix --ignore-path ./.gitignore",
    "lint:format": "prettier  --log-level warn --write \"./**/*.{js,jsx,ts,tsx,css,md,json}\" ",
    "lint": "eslint ./src --ext .jsx,.js,.ts,.tsx --quiet --fix --ignore-path ./.gitignore;prettier  --log-level warn --write \"./**/*.{js,jsx,ts,tsx,css,md,json}\"",
    "prepare": "cd .. && husky frontend/.husky",
    "test": "vitest",
    "test:ci": "vitest run --pool=forks",
    "coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@digdir/designsystemet-css": "1.11.1",
    "@digdir/designsystemet-react": "1.11.1",
    "@digdir/designsystemet-theme": "1.9.0",
    "@digdir/designsystemet-types": "1.11.1",
    "@hookform/resolvers": "5.2.2",
    "@navikt/aksel-icons": "8.5.0",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/react-table": "^8.20.6",
    "classnames": "^2.5.1",
    "dompurify": "3.4.0",
    "npm-check-updates": "^19.3.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.70.0",
    "react-loading-skeleton": "^3.5.0",
    "react-router-dom": "7.13.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@faker-js/faker": "10.2.0",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/dompurify": "3.0.5",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "@vitejs/plugin-react-swc": "^4.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "3.2.4",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "16.2.7",
    "prettier": "^3.4.2",
    "sass": "^1.97.2",
    "typescript": "^5.9.2",
    "vite": "^7.2.4",
    "vitest": "^3.2.4"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{html,css,less,ejs,scss}": [
      "prettier --write"
    ]
  }
}
